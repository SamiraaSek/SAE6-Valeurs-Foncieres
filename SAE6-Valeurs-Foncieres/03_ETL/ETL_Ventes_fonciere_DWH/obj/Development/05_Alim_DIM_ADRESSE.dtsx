                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT
    a.id_adresse,
    a.adresse_numero,
    a.adresse_suffixe,
    a.adresse_code_voie,
    a.adresse_nom_voie,
    a.code_postal,
    a.longitude,
    a.latitude,
    c.code_commune,
    c.nom_commune,
    c.code_departement,
    c.ancien_code_commune,
    c.ancien_nom_commune
FROM Ventes_fonciere.dbo.ADRESSE a
LEFT JOIN Ventes_fonciere.dbo.COMMUNE c
    ON a.id_commune = c.id_commune</property>
